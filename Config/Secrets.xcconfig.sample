// Copy this file to Config/Secrets.xcconfig (which is git-ignored)
// and replace with your own API keys.

// Optional single RapidAPI key fallback.
FLIGHT_API_KEY = your_primary_rapidapi_key_here

// Preferred: comma-separated RapidAPI keys for automatic 429 rotation.
// Example: key_one,key_two,key_three
FLIGHT_API_KEYS =

